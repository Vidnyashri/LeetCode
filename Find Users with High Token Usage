WITH UserStats AS (
    SELECT 
        user_id,
        tokens,
        AVG(tokens) OVER(PARTITION BY user_id) as user_avg,    
        COUNT(prompt) OVER(PARTITION BY user_id) as prompt_count
    FROM prompts
)
SELECT 
    user_id, 
    prompt_count, 
    ROUND(AVG(tokens), 2) AS avg_tokens
FROM UserStats
WHERE prompt_count >= 3 
GROUP BY user_id, prompt_count
HAVING MAX(tokens) > AVG(tokens)
ORDER BY avg_tokens DESC, user_id ASC;
